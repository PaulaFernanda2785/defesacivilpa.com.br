</tr>
<tr>
<td>GRAU_VULNE</td>
<td>Baixo</td>
</tr>
<tr bgcolor="#D4E4F3">
<td>GRAU_RISCO</td>
<td>Alto</td>
</tr>
<tr>
<td>SUG_INTERV</td>
<td>Paralização das obras, estudos para implantação de muro de contenção apropriado, reflorestamento, adequar o projeto estrutual ao terreno</td>
</tr>
<tr bgcolor="#D4E4F3">
<td>ORGÃO_EXEC</td>
<td>CPRM</td>
</tr>
<tr>
<td>PROJETO</td>
