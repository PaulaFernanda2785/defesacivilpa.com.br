,-1.71615358766758 -48.8882645026683,-1.71616239562531 -48.8880883435137,-1.71618177313232 -48.8879350850492,-1.71620115063933 -48.8879271578873,-1.71616415721686 -48.887916588338,-1.71609985912543 -48.8879104227676,-1.71608664718884 -48.8878946242382,-1.7160169157486 -48.8878872460237,-1.71598434983653 -48.8878848796902,-1.71597390532989 -48.8878795498762,-1.71594674865896 -48.8878663829789,-1.71587966018218 -48.8878690253662,-1.71584795153436 -48.8878954492394,-1.71584266675972 -48.8878813565071,-1.71566474601357 -48.8879194509242,-1.71565791984633 -48.8879181297306,-1.71564074432876 -48.8879486642146,-1.71563648139755 -48.887939406453,-1.71555183900542 -48.8879278460085,-1.71543953754436 -48.8880417989616,-1.71540815919495 -48.8880252840408,-1.71529090325767 -48.8880417989616,-1.71526447938448 -48.8880269355329,-1.7151670413521 -48.8881276765494,-1.71514392046305 -48.888164653066,-1.71513792427117</coordinates></LinearRing></outerBoundaryIs></Polygon>
