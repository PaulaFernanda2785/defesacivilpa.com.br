      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.8694293193999,-1.72205929678913 -48.8694361718268,-1.72206295660806 -48.8695436289111,-1.72187622790418 -48.8692705822215,-1.72167540646794 -48.8691965953766,-1.7214974857218 -48.868752674307,-1.72113107468023 -48.8688812704898,-1.72093201483554 -48.8686452172227,-1.72079461069495 -48.8684708196596,-1.72069419997683 -48.8682241968432,-1.72098486258192 -48.8686505019973,-1.72132837293338 -48.8685377601384,-1.72154152551045 -48.8692811517708,-1.7219801618054 -48.8693301460353,-1.72200632919667 -48.8693301460353,-1.72205607539108 -48.8693242006638,-1.72213931059162 -48.869243938149,-1.72224335459231 -48.8691696210057,-1.72232658979286 -48.8691250307197,-1.72242468842207 -48.8691250307197,-1.72249008750822 -48.8691577302627,-1.72254062316569 -48.8693212279781,-1.72251089630835 -48.8693985178072,-1.72242766110781 -48.8693985178072,-1.72233848053579 -48.8694104085501,-1.7221987643063 -48.8694293193999,-1.72205929678913</coordinates></LinearRing></outerBoundaryIs></Polygon>
