	<Style><LineStyle><color>ff0000ff</color></LineStyle><PolyStyle><fill>0</fill></PolyStyle></Style>
	<ExtendedData><SchemaData schemaUrl="#setores">
		<SimpleData name="UF">PA</SimpleData>
		<SimpleData name="MUNIC">ABAETETUBA</SimpleData>
		<SimpleData name="LOCAL">Final da Rua Barão do Rio Branco, Bairro São João</SimpleData>
		<SimpleData name="TIPOLO_G1">Inundação</SimpleData>
		<SimpleData name="COBRADE_01">1.2.1.0.0</SimpleData>
		<SimpleData name="TIPOLO_G2">Alagamento</SimpleData>
		<SimpleData name="COBRADE_02">1.2.3.0.0</SimpleData>
		<SimpleData name="SITUACAO_01">Instalado</SimpleData>
		<SimpleData name="DESCRICAO">O setor está localizado na planície de inundação do Rio Maratauíra e de um pequeno afluente deste rio. A área é atingida pela inundação principalmente no período chuvoso (fevereiro a maio), e é agravada quando coincide com as preamares dos meses de março e abril, que levam ao represamento das águas fluviais e pluviais, tendo como consequência o transbordamento do rio que atinge as residências. O acesso a área é feito através de pontes de concreto e madeira e as casas são em palafita sobre área permanentemente alagada (Figuras 1, 2, 3, 4 e 5).</SimpleData>
		<SimpleData name="GRAU_VULNE">Alto</SimpleData>
		<SimpleData name="GRAU_RISCO">Alto</SimpleData>
		<SimpleData name="SUG_INTERV">- Implantação de rede de esgotamento sanitário, manutenção e limpeza (dragagem e coleta de lixo) das drenagens pluviais e igarapés, a fim de evitar que o acúmulo de resíduos impeça o perfeito escoamento das águas durante a estação chuvosa;
- Conscientização dos moradores, com objetivo de evitar descarte de resíduos nas águas;
- Implantação de políticas de controle urbano para evitar construções e ocupações em áreas de preservação permanente (APP), como margens e leitos de rio;
- Instalação de sistema de alerta para as áreas de risco, através de meios de veiculação pública (mídia, sirenes, celulares), permitindo a remoção eficaz dos moradores em caso de alertas de chuvas intensas ou contínuas.
</SimpleData>
		<SimpleData name="ORGAO_EXEC">CPRM</SimpleData>
		<SimpleData name="PROJETO">Cartografia de Risco Geológico</SimpleData>
		<SimpleData name="EQUIPE_EXECUTORA">Sheila Teixeira (Pesquisadora em Geociências)
Almir Conceição (Pesquisador em Geociências)
</SimpleData>
		<SimpleData name="CD_GEOCMU">1500107</SimpleData>
		<SimpleData name="SEQUENCIA">4</SimpleData>
		<SimpleData name="NUM_EDIF">20</SimpleData>
		<SimpleData name="Sigla_risco">ABAETET</SimpleData>
		<SimpleData name="M_tipolo">2</SimpleData>
		<SimpleData name="NUM_PESS">80</SimpleData>
		<SimpleData name="NUM_SETOR">PA_ABAETET_SR_004_CPRM</SimpleData>
		<SimpleData name="DATA_SETOR">2023/04/10</SimpleData>
		<SimpleData name="cd_setor">SR_004</SimpleData>
		<SimpleData name="TIPOLOGIA">Inundação, Alagamento</SimpleData>
	</SchemaData></ExtendedData>
      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.8857604002857,-1.71183339450054 -48.8854732608637,-1.71167132807831 -48.8852671546528,-1.71150926165608 -48.8851632207516,-1.71144408276887 -48.8850381477518,-1.71140885093795 -48.8850222934279,-1.71145112913506 -48.8849888231885,-1.71153216234617 -48.8849747304562,-1.71162200351502 -48.8849712072731,-1.71173122219087 -48.8849394986252,-1.71184572564136 -48.8849254058929,-1.71195142113412 -48.884893697245,-1.7120465470776 -48.8848919356535,-1.71217162007737 -48.8849254058929,-1.71230021626022 -48.8850117238786,-1.71238653424598 -48.8850909954982,-1.71245875949936 -48.8851685055262,-1.71248166018946 -48.8852618698781,-1.71251160724574 -48.885293578526,-1.71252041520347 -48.8853217639907,-1.71253274634429 -48.8854803072298,-1.71232311695032 -48.8855032079199,-1.71227026920394 -48.8856159497789,-1.71213991142954 -48.8856547047929,-1.71205711662688 -48.8857604002857,-1.71188624224692 -48.8857885857504,-1.711851010416 -48.8857604002857,-1.71183339450054</coordinates></LinearRing></outerBoundaryIs></Polygon>
