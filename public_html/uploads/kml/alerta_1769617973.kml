663372,-1.71414075249049 -48.8878699131572,-1.71423485055757 -48.8878886230722,-1.7142787037653 -48.8879370668397,-1.71436193896585 -48.8880207424382,-1.71453501533524 -48.8880980322672,-1.714696971658 -48.8882363172036,-1.7146414815243 -48.8883039182792,-1.71461076377172 -48.8883728405484,-1.71458158741174 -48.8884882247947,-1.71453226284845 -48.8885743225815,-1.71450110469798 -48.8885984343658,-1.71449229674025 -48.8886456670391,-1.71447534142162 -48.8886476984654,-1.71447470844097 -48.8887225164703,-1.71444770645424 -48.8887691986462,-1.71443537531342</coordinates></LinearRing></outerBoundaryIs></Polygon>
