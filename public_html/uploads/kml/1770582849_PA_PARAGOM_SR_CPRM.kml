9848341,-2.98214637282142 -47.3509318311912,-2.98208032143095 -47.3510288441709,-2.98214637282142 -47.3511299853626,-2.98223100116546 -47.3512146137067,-2.98231975772141 -47.3513322677459,-2.98240851427735 -47.3513474618591,-2.9823678564435 -47.3514492910861,-2.9821862151197 -47.3514630517925,-2.98204447984432 -47.3514891397983,-2.98198124434524 -47.351481399401,-2.98197401997441</coordinates></LinearRing></outerBoundaryIs></Polygon>
