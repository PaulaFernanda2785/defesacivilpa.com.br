	<ExtendedData><SchemaData schemaUrl="#PA_MONTEAL_SR_CPRM">
		<SimpleData name="UF">PA</SimpleData>
		<SimpleData name="MUNIC">MONTE ALEGRE</SimpleData>
		<SimpleData name="LOCAL">Rua Adelino Azevedo - Bairro Pajuçara</SimpleData>
		<SimpleData name="DATA_SETOR">2021-10-27</SimpleData>
		<SimpleData name="TIPOLO_G1">Enxurrada</SimpleData>
		<SimpleData name="COBRADE_01">1.2.2.0.0</SimpleData>
		<SimpleData name="TIPOLO_G2">Outros</SimpleData>
		<SimpleData name="SITUACAO_01">Instalado</SimpleData>
		<SimpleData name="DESCRICAO">Setor de risco alto a enxurrada, localizado na Rua Adelino Azevedo, caracterizado por conter 7 (sete) moradias, instaladas numa área topograficamente mais baixa, associado a uma declividade que varia de 2,5 a 4°. Este terreno, composto por um material inconsolidado, predominantemente arenoso (Figura 1), com pouca cobertura vegetal e sem um sistema de drenagem, possui alto potencial a processos erosivos (Figura 2 e 3), assim como possibilita o escoamento superficial concentrado e com alta energia de transporte (enxurrada) nos períodos chuvosos. Este processo de enxurrada provoca destruição de casas e muros (Figura 4), e deixa as áreas mais baixas assoreadas (Figura 5), aterrando  algumas residências (Figura 6), causando danos materiais e remanejamento dos moradores.</SimpleData>
		<SimpleData name="OBS_OCUP">Loteamento recente, moradias em alvenaria.</SimpleData>
		<SimpleData name="GRAU_VULNE">Médio</SimpleData>
		<SimpleData name="GRAU_RISCO">Alto</SimpleData>
		<SimpleData name="SUG_INTERV">1- Implantação de um sistema de drenagem de água pluvial eficiente que seja capaz de reduzir ao máximo os efeitos dos processos de enxurrada e erosões (sulcos e ravinas), com base nos volumes máximos de chuva já registrados no município;
2- Implantação de um sistema de alerta para os moradores de área de risco; 
3- Em caso de chuvas intensas, alerta e atenção máxima para enxurradas e eventuais remoções de emergência; 
4- Proibição de construção de moradias ou estabelecimentos comerciais em áreas de risco.
</SimpleData>
		<SimpleData name="ORGAO_EXEC">CPRM</SimpleData>
		<SimpleData name="PROJETO">Setorização de Áreas em Alto e Muito Alto Risco a Movimentos de Massa, Enchentes e Inundações</SimpleData>
		<SimpleData name="EQUIPE_EXECUTORA">Dianne Fonseca (Pesquisadora em Geociências) &amp; Iris Bandeira (Pesquisadora em Geociências)</SimpleData>
		<SimpleData name="CD_GEOCMU">1504802</SimpleData>
		<SimpleData name="SEQUENCIA">4</SimpleData>
		<SimpleData name="NUM_EDIF">7</SimpleData>
		<SimpleData name="Sigla_risco">MONTEAL</SimpleData>
		<SimpleData name="M_tipolo">2</SimpleData>
		<SimpleData name="NUM_PESS">28</SimpleData>
		<SimpleData name="SITUACAO_02">Instalado</SimpleData>
		<SimpleData name="cd_setor">SR_004</SimpleData>
		<SimpleData name="TIPOLOGIA">Enxurrada, Outros</SimpleData>
		<SimpleData name="NUM_SETOR">PA_MONTEAL_SR_004_CPRM</SimpleData>
	</SchemaData></ExtendedData>
      <Polygon><outerBoundaryIs><LinearRing><coordinates>-54.0636972491995,-1.98809836817757 -54.0627330088383,-1.98754420705046 -54.0626055517791,-1.98787116211545 -54.0623811165226,-1.98851675982853 -54.06227247021,-1.9886660214924 -54.0621078080218,-1.98862710133882 -54.0620658940103,-1.98862410748085 -54.0620329615726,-1.98870793550395 -54.0620269738567,-1.98878278195313 -54.0618712932424,-1.98876182494736 -54.0618682993844,-1.9888785854081 -54.0617964467932,-1.98887259769216 -54.0617335757758,-1.98908815546582 -54.061625796889,-1.98905222917021 -54.0613593435299,-1.98900432744273 -54.061164742762,-1.98961507446811 -54.061997035277,-1.98984560153161 -54.0617814775033,-1.99069885105236 -54.0622814517839,-1.99081261765513 -54.0623473166592,-1.99055215201195 -54.0621467281754,-1.99050724414244 -54.0624880279837,-1.98899235201086 -54.0636972491995,-1.98809836817757</coordinates></LinearRing></outerBoundaryIs></Polygon>
