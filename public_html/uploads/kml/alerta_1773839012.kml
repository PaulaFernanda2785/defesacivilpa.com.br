0637356879661,-2.0013575992688 -54.0637805338398,-2.00137441647146 -54.0638814370557,-2.00100724088019 -54.0639038599926,-2.00100724088019 -54.0639627202019,-2.00101564948152 -54.0639851431388,-2.00086709752475 -54.0640720320191,-2.00087550612608 -54.0641729352351,-2.00039061011624 -54.0641336950955,-2.0003793986478 -54.064223386843,-2.00005146319607 -54.0643355015274,-2.00008509760137 -54.0643943617367,-1.99975716214963 -54.0644195875406,-1.99958618725599 -54.0644644334144,-1.99960580732575 -54.0644728420157,-1.99952732704671 -54.0645260964908,-1.99953853851514 -54.0645288993579,-1.99949649550851 -54.0650754584441,-1.99960580732575 -54.0652380247364,-1.9996506531995 -54.0652716591417,-1.99951891844538 -54.0652884763444,-1.99949649550851 -54.0653753652248,-1.99951611557827 -54.0654089996301,-1.99935635215307 -54.065484677042,-1.99937597222283 -54.0655070999789,-1.99932271774776 -54.0655435372513,-1.99931711201354 -54.0655799745237,-1.9993367320833 -54.0656500462014,-1.99928628047534 -54.065638834733,-1.99926385753847</coordinates></LinearRing></outerBoundaryIs></Polygon>
