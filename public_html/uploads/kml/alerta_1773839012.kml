  <Placemark>
	<Style><LineStyle><color>ff0000ff</color></LineStyle><PolyStyle><fill>0</fill></PolyStyle></Style>
	<ExtendedData><SchemaData schemaUrl="#PA_MONTEAL_SR_CPRM">
		<SimpleData name="UF">PA</SimpleData>
		<SimpleData name="MUNIC">MONTE ALEGRE</SimpleData>
		<SimpleData name="LOCAL">Rua Justo Santos e Avenida Presidente Vargas - Bairro Surubeju</SimpleData>
		<SimpleData name="DATA_SETOR">2021-10-29</SimpleData>
		<SimpleData name="TIPOLO_G1">Deslizamento</SimpleData>
		<SimpleData name="TIPOLO_E1">Deslizamento planar</SimpleData>
		<SimpleData name="COBRADE_01">1.1.3.2.1</SimpleData>
		<SimpleData name="SITUACAO_01">Potencial</SimpleData>
		<SimpleData name="DESCRICAO">Setor caracterizado por conter aproximadamente 13 moradias (Figura 1, 2, 3 e 4) localizadas na rua Justo Santos, instaladas na borda de uma escarpa subvertical, de 22m de altura, composta por arenito pouco consolidado, com alta suscetibilidade a movimentos de massa. Além dessas, aproximadamente 10 moradias localizadas na Avenida Presidente Vargas, mais especificamente na base da escarpa, também estão com risco muito alto de serem atingidas por deslizamentos e rolamentos de blocos (Figura 5 e 6).</SimpleData>
		<SimpleData name="OBS_OCUP">Residencias em madeira e alvenaria.</SimpleData>
		<SimpleData name="GRAU_VULNE">Alto</SimpleData>
		<SimpleData name="GRAU_RISCO">Muito Alto</SimpleData>
		<SimpleData name="SUG_INTERV">1- Implantação de um sistema de alerta para os moradores de área de risco; 
2- Em caso de chuvas intensas, alerta e atenção máxima para deslizamentos e eventuais remoções de emergência;
3- Realizar palestras educacionais visando o conhecimento sobre as áreas de risco do município;
4- Desestimular, através de ações fiscais, edificações em bordas e na base dos taludes sem execução de contenções adequadamente projetadas por especialistas em geotecnia; 
5- Fazer uma avaliação detalhada quanto à necessidade de obras estruturais.
</SimpleData>
		<SimpleData name="ORGAO_EXEC">CPRM</SimpleData>
		<SimpleData name="PROJETO">Setorização de Áreas em Alto e Muito Alto Risco a Movimentos de Massa, Enchentes e Inundações</SimpleData>
		<SimpleData name="EQUIPE_EXECUTORA">Dianne Fonseca (Pesquisadora em Geociências) &amp; Iris Bandeira (Pesquisadora em Geociências)</SimpleData>
		<SimpleData name="CD_GEOCMU">1504802</SimpleData>
		<SimpleData name="SEQUENCIA">16</SimpleData>
		<SimpleData name="NUM_EDIF">23</SimpleData>
		<SimpleData name="Sigla_risco">MONTEAL</SimpleData>
		<SimpleData name="M_tipolo">1</SimpleData>
		<SimpleData name="NUM_PESS">92</SimpleData>
		<SimpleData name="cd_setor">SR_016</SimpleData>
		<SimpleData name="TIPOLOGIA">Deslizamento planar</SimpleData>
		<SimpleData name="NUM_SETOR">PA_MONTEAL_SR_016_CPRM</SimpleData>
	</SchemaData></ExtendedData>
      <Polygon><outerBoundaryIs><LinearRing><coordinates>-54.0820107016926,-2.01052961776345 -54.0821529930434,-2.01030284092309 -54.0817661384334,-2.01000936501204 -54.0814904489412,-2.00983150082352 -54.0811702934018,-2.00968031626328 -54.0809257301426,-2.00956915114546 -54.0808501378625,-2.00979148138111 -54.080996875818,-2.00988486008008 -54.0816594199203,-2.0102717146901 -54.0815660412213,-2.01052072455403 -54.0812814585197,-2.01041400604092 -54.0811080409359,-2.01036953999379 -54.0810146622369,-2.01055185078702 -54.0811614001924,-2.01062299646242 -54.0813837304281,-2.01069858874254 -54.0817439054098,-2.01074750139438 -54.0818372841088,-2.01040511283149 -54.0820107016926,-2.01052961776345</coordinates></LinearRing></outerBoundaryIs></Polygon>
