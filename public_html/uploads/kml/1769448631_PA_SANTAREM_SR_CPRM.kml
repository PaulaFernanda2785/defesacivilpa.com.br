      <Polygon><outerBoundaryIs><LinearRing><coordinates>-54.7199028190382,-2.47573536831995 -54.7191441272877,-2.47576654743298 -54.7191545203254,-2.47632777146757 -54.719166645536,-2.47657893654478 -54.7191631811901,-2.47667593822977 -54.719135466423,-2.47667940257566 -54.719135466423,-2.47676601122297 -54.71913373425,-2.4768456911785 -54.7190973586182,-2.47706048062384 -54.7192515220104,-2.47747793430388 -54.7195321340277,-2.47736707523532 -54.7194437932074,-2.47716614317356 -54.7196447252692,-2.4771003206016 -54.7201314658671,-2.47694962155528 -54.7200413928739,-2.47662916956022 -54.7199790346478,-2.47624462716615 -54.7199028190382,-2.47573536831995</coordinates></LinearRing></outerBoundaryIs></Polygon>
