      <Polygon><outerBoundaryIs><LinearRing><coordinates>-54.6915506122538,-2.47582111088079 -54.6910500142724,-2.47577607438419 -54.6907624735633,-2.47579686045954 -54.6904610754706,-2.47578993176776 -54.6899639418351,-2.47577953873008 -54.6899708705269,-2.47613463418406 -54.6896746689531,-2.47594582733292 -54.689451218643,-2.47628533323038 -54.6897820636757,-2.4764620148709 -54.6897993854052,-2.47646894356269 -54.6897231697955,-2.47660578522544 -54.6896556150506,-2.47683443205435 -54.6902584112359,-2.47723109965904 -54.6904073781093,-2.47733329786287 -54.690901047399,-2.47766587506855 -54.6909772630086,-2.47754289078936 -54.6911210333632,-2.47761737422605 -54.6910881220772,-2.47767973245212 -54.6912041776646,-2.47773342981345 -54.6912284280858,-2.47766933941444 -54.6913618054027,-2.47771437591104 -54.6913773949592,-2.47766241072266 -54.6913808593051,-2.47765548203087 -54.691481325336,-2.47767973245212 -54.6915817913669,-2.47725361790734 -54.6916302922093,-2.47709772234218 -54.6916545426306,-2.47702497107843 -54.6914778609901,-2.47697647023594 -54.6915350226973,-2.47672876950462 -54.6915869878857,-2.47674262688819 -54.6916458817659,-2.47628013671155 -54.691640685247,-2.47624722542557 -54.6915402192161,-2.47624029673378 -54.6915506122538,-2.47582111088079</coordinates></LinearRing></outerBoundaryIs></Polygon>
