      <Polygon><outerBoundaryIs><LinearRing><coordinates>-54.2817075601009,-2.44010335226942 -54.2818677322586,-2.44027080497973 -54.2819623794427,-2.44040185492694 -54.2820497460741,-2.44054018542676 -54.2821516738108,-2.44070035758446 -54.282282723758,-2.44095517692624 -54.2824210542579,-2.4412027157154 -54.2825084208893,-2.44138472953097 -54.2826321902839,-2.4415594627939 -54.2826540319418,-2.44169779329373 -54.2826977152575,-2.44189436821454 -54.2828287652047,-2.44203269871436 -54.2829598151519,-2.44221471252992 -54.2830107790203,-2.4425641790558 -54.2829379734941,-2.44276075397661 -54.2829088512836,-2.44281171784496 -54.2828360457573,-2.44296460945004 -54.2828069235469,-2.44302285387102 -54.2823773709421,-2.44291364558168 -54.2823482487316,-2.44250593463482 -54.282282723758,-2.44212006534583 -54.2822608821002,-2.44186524600405 -54.2820497460741,-2.44128280179425 -54.2818531711533,-2.44086781029477 -54.2816784378904,-2.44060571040036 -54.281569229601,-2.44035089105858 -54.2814673018643,-2.44019799945351 -54.2817075601009,-2.44010335226942</coordinates></LinearRing></outerBoundaryIs></Polygon>
