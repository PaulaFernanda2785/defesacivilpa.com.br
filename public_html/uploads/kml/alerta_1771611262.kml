902127,-1.46813381886508 -48.5014209777625,-1.46820457012029 -48.5013712764675,-1.46830338798914 -48.501349057065,-1.46840103641576 -48.5013098807501,-1.46848582097779 -48.5012654419452,-1.46857294442429 -48.5012490697539,-1.46864369567951 -48.5012274350726,-1.46873315801048 -48.5011713018453,-1.46886179665632 -48.5011292019249,-1.46895008954506 -48.5010678062075,-1.4691056253623 -48.5010175201914,-1.46920619739451 -48.5009783438766,-1.46926642366961 -48.5009473536573,-1.46931787912794 -48.5009374133984,-1.4693599790484 -48.5008590607686,-1.46943599279367 -48.5007292526805,-1.46955644534387 -48.500616986226,-1.46965000072266 -48.5005210919627,-1.4697517421971 -48.5004041477392,-1.46984529757589 -48.5002383793023,-1.46998826188911</coordinates></LinearRing></outerBoundaryIs></Polygon>
