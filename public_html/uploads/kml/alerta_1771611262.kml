      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.4812815507582,-1.40977818560577 -48.4809347643946,-1.40977417651486 -48.4806100280309,-1.40980224015122 -48.4804977734855,-1.40978219469668 -48.4803514416673,-1.4098343128785 -48.4801449734855,-1.40993053106032 -48.4800587780309,-1.40993253560577 -48.4799545416673,-1.40977016742395 -48.4796057507582,-1.40994055378759 -48.4788841143945,-1.41038957196942 -48.4788139553036,-1.41037754469669 -48.4787838871218,-1.41035349015124 -48.4785293098491,-1.41051786287851 -48.4784310871218,-1.41060004924215 -48.4787077143945,-1.41087066287852 -48.47890816894,-1.41105508106034 -48.4790635212127,-1.41123148106035 -48.4791757757582,-1.41134674242399 -48.4793371416673,-1.41147403106035 -48.4797099871218,-1.41124250606035 -48.4803334007582,-1.41074838560579 -48.4808626007582,-1.41030538106033 -48.4811813234855,-1.40994656742395 -48.4812574962127,-1.40982429015122 -48.4812815507582,-1.40977818560577</coordinates></LinearRing></outerBoundaryIs></Polygon>
