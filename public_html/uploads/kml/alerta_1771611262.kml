		<SimpleData name="NUM_EDIF">12</SimpleData>
		<SimpleData name="Sigla_risco">BELEM</SimpleData>
		<SimpleData name="M_tipolo">1</SimpleData>
		<SimpleData name="NUM_PESS">48</SimpleData>
		<SimpleData name="cd_setor">SR_103</SimpleData>
		<SimpleData name="NUM_SETOR">PA_BELEM_SR_103_CPRM</SimpleData>
	</SchemaData></ExtendedData>
