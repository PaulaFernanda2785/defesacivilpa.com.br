288484852,-1.40804124696936 -48.470818825758,-1.40796306969663 -48.4709150439398,-1.40792097424209 -48.4710934484852,-1.40786685151481 -48.4713650643943,-1.40782475606027 -48.4714191871216,-1.40781373106027 -48.4713891189398,-1.40767241060572 -48.4716256553034,-1.40766539469663 -48.4717629666671,-1.40766739924208 -48.472196950758,-1.40765036060572 -48.4722049689398,-1.40751605606026 -48.4722089780307,-1.40739879015117 -48.472219000758,-1.40718530606025 -48.4725036462125,-1.40719031742389 -48.4725116643943,-1.40662102651478 -48.4726980871216,-1.40663706287842 -48.4728424143943,-1.40664307651479 -48.4728494303034,-1.40627123333298</coordinates></LinearRing></outerBoundaryIs></Polygon>
