513644,-1.33601444825201 -48.4600119709002,-1.33634072166867 -48.4600581812982,-1.33652976420623 -48.4601183948472,-1.33676781777203 -48.4601842096566,-1.33701987448877 -48.4602528250962,-1.33729013530171 -48.4603004358093,-1.33746657500342 -48.4603396446319,-1.33769622667867 -48.4603872553451,-1.33794268213503 -48.4604208629073,-1.3382675552366 -48.4604796761412,-1.33849720691185 -48.4606841221448,-1.33853641573445 -48.461003393986,-1.33859802959855 -48.4612890582649,-1.33864844094189 -48.4614262891441,-1.33863723842115 -48.4615075074194,-1.33864283968152 -48.4615495168722,-1.33867084598338 -48.461560719393,-1.33872405795691 -48.461605529476,-1.33881927938323 -48.4615887256948,-1.33892010206993 -48.4616027288458,-1.33907973799053</coordinates></LinearRing></outerBoundaryIs></Polygon>
