      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.4964936790857,-1.47347502700268 -48.4961919629891,-1.47314524429243 -48.495788505418,-1.47269968680092 -48.4952727813924,-1.47211028791452 -48.4948903737816,-1.47167174707643 -48.4941957250941,-1.47088763605791 -48.4922801787133,-1.46864581529356 -48.4918837377956,-1.46897910633051 -48.4905154903808,-1.47012983748968 -48.49013834526,-1.47045435770987 -48.4905277695242,-1.47096306508206 -48.4917916442196,-1.47252251630233 -48.4925012032956,-1.4734153854487 -48.4927932714938,-1.47379954722287 -48.4940904752929,-1.47537566299499 -48.4941667813987,-1.47543355038562 -48.4944351683916,-1.47528620066402 -48.4946588242191,-1.47510201351202 -48.4955508162838,-1.47430737751339 -48.4964936790857,-1.47347502700268</coordinates></LinearRing></outerBoundaryIs></Polygon>
