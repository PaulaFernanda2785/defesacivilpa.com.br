      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.4857597053037,-1.41833158106052 -48.4859040325765,-1.41846388106052 -48.4859200689401,-1.41861622651507 -48.4858479053037,-1.41872447196962 -48.4854870871219,-1.41891690833326 -48.4850340598492,-1.41912137196963 -48.484645178031,-1.41930178106054 -48.4841640871219,-1.41951025378782 -48.483630878031,-1.41965458106055 -48.4833342053037,-1.41975480833328 -48.4831056871219,-1.41913740833326 -48.4826967598491,-1.41818725378779 -48.4821755780309,-1.41748967196959 -48.4824602234855,-1.4173212901514 -48.4830696053037,-1.41695646287867 -48.4835707416673,-1.41650744469684 -48.4837351143946,-1.41661168106048 -48.4841640871219,-1.41707272651503 -48.4846211234855,-1.41751372651504 -48.4851423053037,-1.41795873560596 -48.4855672689401,-1.41825941742415 -48.4857597053037,-1.41833158106052</coordinates></LinearRing></outerBoundaryIs></Polygon>
