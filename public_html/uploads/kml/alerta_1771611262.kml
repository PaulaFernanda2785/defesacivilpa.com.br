      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.53666813309,-1.24399545077342 -48.5365327070615,-1.24419460669775 -48.5365061529382,-1.24420522834705 -48.5363415173741,-1.24440438427139 -48.5362007805209,-1.24429816777841 -48.535882131042,-1.24405652525688 -48.5350509869844,-1.24278989357812 -48.5346314318372,-1.24220570286674 -48.5340525519504,-1.24146749824054 -48.5319760195127,-1.2387695993189 -48.5315830184887,-1.2383022467498 -48.5311103550949,-1.23806857046525 -48.5309563411801,-1.2378030292328 -48.5306695566491,-1.23731974418975 -48.5304783669617,-1.23694267563968 -48.5302340690279,-1.23655498544031 -48.5297614056341,-1.23518479268089 -48.5298145138806,-1.23458998032022 -48.5302234473786,-1.2344359664054 -48.5304518128385,-1.23495642722099 -48.5309244762322,-1.23651780966777 -48.5316016063749,-1.23705685836963 -48.5320158506976,-1.23797563103389 -48.5327434336745,-1.23870055859846 -48.5336462738648,-1.23964588538597 -48.5340180315902,-1.24038409001217 -48.534565046529,-1.24098421319749 -48.5350270882735,-1.24153653896098 -48.5354041568236,-1.24181270184272 -48.5360202124828,-1.24296515079153 -48.5362167129948,-1.24355465232756 -48.53666813309,-1.24399545077342</coordinates></LinearRing></outerBoundaryIs></Polygon>
