      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.4584622888636,-1.30499963943107 -48.4583248712758,-1.30498171539788 -48.4583039599037,-1.30485027248782 -48.4583368206313,-1.30470986756116 -48.4583398079701,-1.30460232336202 -48.4583487699867,-1.30455153860132 -48.4583905927308,-1.30448880448515 -48.4584174787806,-1.3044589310965 -48.4585100862854,-1.30403472897767 -48.4585041116077,-1.30397199486151 -48.4582591498208,-1.3039301721174 -48.4582501878042,-1.30384951396804 -48.4583039599037,-1.30357467879246 -48.4582113523989,-1.30347012193218 -48.4581755043325,-1.30345817257672 -48.4581605676382,-1.3033745270885 -48.4581336815884,-1.30330581829461 -48.4581008208609,-1.30321022345093 -48.458011200695,-1.30318333740114 -48.4579126185124,-1.30315047667363 -48.4578439097185,-1.30309969191292 -48.4577333781805,-1.30301903376357 -48.4576706440644,-1.30302202110243 -48.4576168719648,-1.30303397045789 -48.4575929732539,-1.30306683118541 -48.4575511505098,-1.3031355399793 -48.45752426446,-1.30329088160028 -48.4574884163936,-1.30334166636099 -48.4575003657491,-1.30338050176623 -48.4575392011543,-1.30341336249375 -48.4575601125264,-1.30348207128764 -48.4575750492207,-1.30356870411473 -48.457589985915,-1.30364637492522 -48.4575840112373,-1.30370313436365 -48.4576258339814,-1.30384951396804 -48.4577064921307,-1.30387640001783 -48.4577154541473,-1.30403771631654 -48.4577781882635,-1.30405862768859 -48.4577722135858,-1.30416617188773 -48.457790137619,-1.30427072874801 -48.4578259856853,-1.30439320964147 -48.4578528717351,-1.30444996907991 -48.4578946944792,-1.30451270319607 -48.4579126185124,-1.3045873866677 -48.4579365172233,-1.30468596885024 -48.4579365172233,-1.3047666269996 -48.4579305425456,-1.3048263737769 -48.4579156058513,-1.30486222184328 -48.4580261373893,-1.30490105724852 -48.4580291247282,-1.30500860144766 -48.4580619854557,-1.30509523427475 -48.458142643605,-1.30526252525119 -48.4583248712758,-1.30516394306864 -48.4584772255579,-1.30508328491929 -48.45852801