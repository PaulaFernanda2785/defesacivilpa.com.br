2373294744,-1.42901533086189 -48.4922215543737,-1.42901665106587 -48.4921481518612,-1.42900762855287 -48.4921272667055,-1.42903519136117 -48.4921276067737,-1.42903699578071 -48.4921343147113,-1.42906164128032 -48.4921276221094,-1.42908485251921 -48.4921268355351,-1.42908598147675 -48.4921155120667,-1.42909076375443 -48.4920775422436,-1.42907605501634 -48.4920324882139,-1.42908377282052 -48.4920317039103,-1.42908490822788 -48.4920372219727,-1.42910637991464 -48.4920395435592,-1.4291075795512 -48.4920638582688,-1.42913840902954 -48.4920687016447,-1.42917786248099 -48.4920859583504,-1.42920771913716 -48.4920904062828,-1.42921020785744 -48.4920970704287,-1.4292139468539 -48.4921460126607,-1.4292432287095 -48.492150509376,-1.42926094961139</coordinates></LinearRing></outerBoundaryIs></Polygon>
