      <Polygon><outerBoundaryIs><LinearRing><coordinates>-48.5676935794047,-6.38257285421326 -48.5677900869656,-6.38245436968308 -48.567680202119,-6.38235117347937 -48.5675273188543,-6.38221357854109 -48.5674040567221,-6.38233301859168 -48.5676935794047,-6.38257285421326</coordinates></LinearRing></outerBoundaryIs></Polygon>
